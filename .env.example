# Required: base origin for the HVT API.
VITE_API_URL=http://localhost:8000

# Optional: links surfaced in the dashboard UI.
VITE_PUBLIC_DOCS_URL=https://docs.hvts.app
VITE_PUBLIC_STATUS_URL=https://api.hvts.app/healthz/

# Optional: only needed when exercising runtime-auth flows from the playground.
VITE_RUNTIME_API_KEY=
